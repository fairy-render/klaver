{
  "compilerOptions": {
    "lib": [],
    "typeRoots": ["./@types"],
    "jsxImportSource": "@wilbur/template",
    "jsx": "preserve",
    "target": "ES2020",
    "noEmit": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true
  }
}
